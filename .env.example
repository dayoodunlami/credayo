# Infrastructure Resilience Platform - Environment Variables

# MapTiler API Key (Required for mapping)
# Get your free key at: https://cloud.maptiler.com/
VITE_MAPTILER_KEY=your_maptiler_key_here

# Google Maps API Key (Optional - for Cesium 3D photorealistic tiles)
# Get your key at: https://console.cloud.google.com/
# Enable: Maps JavaScript API + 3D Tiles API
VITE_GOOGLE_MAPS_KEY=your_google_key_here

# Weather API Key (Optional - for weather overlay features)
# MapTiler Weather or OpenWeatherMap
VITE_WEATHER_API_KEY=your_weather_key_here

# Development settings
VITE_APP_TITLE="CReDo Infrastructure Resilience Platform"
VITE_APP_VERSION="0.1.0"